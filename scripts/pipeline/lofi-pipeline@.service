[Unit]
Description=Lofi Engine YouTube Pipeline
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=%i
WorkingDirectory=/opt/lofi-engine
ExecStart=/opt/lofi-engine/scripts/pipeline/lofi_pipeline.sh
StandardOutput=append:/var/log/lofi_pipeline.log
StandardError=append:/var/log/lofi_pipeline.log
Environment=ML_SERVER_URL=http://localhost:5050
Environment=LOFI_DURATION=10800
Environment=LOFI_PRIVACY=public
